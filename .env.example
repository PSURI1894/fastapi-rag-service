# Copy this file to `.env` and adjust. Pydantic Settings loads `.env` automatically.
# NEVER commit the real `.env` — it's in .gitignore.

# Free-form environment name surfaced on /health (local | staging | production).
APP_ENV=local

# Root log level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Mock LLM only: artificial delay per token (ms) so you can *see* streaming work.
# Set to 0 for instant responses.
LLM_RESPONSE_DELAY_MS=40

# --- JWT auth ---
# Secret used to SIGN tokens. Generate a strong one with:  openssl rand -hex 32
# Anyone who has this can mint valid tokens — treat it like a password.
JWT_SECRET_KEY=dev-only-insecure-change-me-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Seed user (learning project only) ---
# A known user created at startup so you have something to log in with.
# Real apps replace this with a DB + registration flow.
DEMO_USERNAME=demo
DEMO_PASSWORD=demo-password
