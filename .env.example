# Copy this file to `.env` and adjust. Pydantic Settings loads `.env` automatically.
# NEVER commit the real `.env` — it's in .gitignore.

# Free-form environment name surfaced on /health (local | staging | production).
APP_ENV=local

# Root log level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Mock LLM only: artificial delay per token (ms) so you can *see* streaming work.
# Set to 0 for instant responses.
LLM_RESPONSE_DELAY_MS=40

# --- Database ---
# Default is a zero-setup local SQLite file. For Postgres (see docker-compose.yml):
#   DATABASE_URL=postgresql+asyncpg://rag:ragpw@localhost:5432/ragdb
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Auto-create tables from the ORM on startup. Keep true for local/SQLite; set false
# in production and run `alembic upgrade head` to manage the schema with migrations.
DB_AUTO_CREATE=true
# Set true to echo every SQL statement to the log (handy while learning).
DB_ECHO=false

# --- RAG backend ---
# "mock" (default): keyword retrieval + templated answer. Zero setup, no key.
# "anthropic": real semantic retrieval (Chroma) + Claude streaming.
#   Requires:  uv sync --extra rag   AND   ANTHROPIC_API_KEY below.
RAG_BACKEND=mock
ANTHROPIC_API_KEY=
# Most capable model by default. Switch to claude-sonnet-4-6 or claude-haiku-4-5
# for lower cost (a deliberate choice).
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024
RAG_TOP_K=2

# --- JWT auth ---
# Secret used to SIGN tokens. Generate a strong one with:  openssl rand -hex 32
# Anyone who has this can mint valid tokens — treat it like a password.
JWT_SECRET_KEY=dev-only-insecure-change-me-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Seed user (learning project only) ---
# A known user created at startup so you have something to log in with.
# Real apps replace this with a DB + registration flow.
DEMO_USERNAME=demo
DEMO_PASSWORD=demo-password
